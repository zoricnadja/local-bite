# ── PgAdmin ───────────────────────────────────────────────────────────────────
PGADMIN_DEFAULT_EMAIL: admin@admin.com
PGADMIN_DEFAULT_PASSWORD: admin

# ── Postgres ──────────────────────────────────────────────────────────────────
POSTGRES_USER: postgres
POSTGRES_PASSWORD: postgres

# ── Auth Service ──────────────────────────────────────────────────────────────
AUTH_DATABASE_URL=postgres://postgres:postgres@auth-db:5432/auth_db
JWT_SECRET=super_secret_change_in_production_please
AUTH_PORT=3001
AUTH_RUST_LOG=auth=debug,tower_http=debug

# ── Raw Materials Service ─────────────────────────────────────────────────────
RAW_MATERIALS_DATABASE_URL=postgres://postgres:postgres@raw-materials-db:5432/raw_materials_db
RAW_MATERIALS_PORT=3002
RAW_MATERIALS_RUST_LOG=raw-materials=debug,tower_http=debug

# ── Product Service ───────────────────────────────────────────────────────────
PRODUCTS_DATABASE_URL=postgres://postgres:postgres@products-db:5432/products_db
PRODUCTS_PORT=3003
PRODUCTS_RUST_LOG=products=debug,tower_http=debug

# ── Production Service ────────────────────────────────────────────────────────
PRODUCTIONS_DATABASE_URL=postgres://postgres:postgres@productions-db:5432/productions_db
PRODUCTIONS_PORT=3004
PRODUCTIONS_RUST_LOG=productions=debug,tower_http=debug

# ── Orders Service ────────────────────────────────────────────────────────────
ORDERS_DATABASE_URL=postgres://postgres:postgres@orders-db:5432/orders_db
ORDERS_PORT=3005
ORDERS_RUST_LOG=orders=debug,tower_http=debug

# ── Frontend ──────────────────────────────────────────────────────────────────
NODE_ENV=development
